{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Athilio Software Docs",
  "colors": {
    "primary": "#1e3985",
    "light": "#2f4acc",
    "dark": "#18145c"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Geral",
        "groups": [
          {
            "group": "Introdução",
            "pages": [
              "index",
              "status",
              "faq",
              "changelog",
              "termos",
              "pagamentos",
              "contato"
            ]
          }
        ]
      },
      {
        "tab": "Spotify",
        "groups": [
          {
            "group": "Athilio Spotify",
            "pages": [
              "athilio_spotify",
              "untitled-page",
              "anti-spoofer"
            ]
          }
        ]
      }
      ,
      {
        "tab": "Aplicações",
        "groups": [
          {
            "group": "Bots",
            "pages": [
              "sistemas-fivem/bot-fivem"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Discord",
          "href": "https://discord.gg/Athilio",
          "icon": "discord"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Discord",
        "href": "https://discord.gg/Athilio"
      },
      {
        "label": "Site",
        "href": "https://athilio.com.br"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://athilio.com.br/dashboard"
    }
  },
  "contextual": {
    "options": ["copy", "view", "claude", "chatgpt", "mcp", "cursor", "vscode"]
  },
  "footer": {
    "socials": {
      "discord": "https://discord.gg/Athilio",
      "x": "https://x.com/Athilio",
      "website": "https://athilio.com.br"
    }
  }
}
