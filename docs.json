{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Athilio Software Docs",
  "colors": {
    "primary": "#27ae60",
    "light": "#2ecc71",
    "dark": "#1e8449"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "groups": [
          {
            "group": "Athilio_Spotify",
            "pages": [
              "index",
              "athilio_spotify"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Discord",
          "href": "https://discord.gg/Athilio",
          "icon": "discord"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Discord",
        "href": "https://discord.gg/Athilio"
      },
      {
        "label": "Site",
        "href": "https://athilio.com.br"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://athilio.com.br/dashboard"
    }
  },
  "contextual": {
    "options": ["copy", "view", "claude", "chatgpt", "mcp", "cursor", "vscode"]
  },
  "footer": {
    "socials": {
      "discord": "https://discord.gg/Athilio",
      "x": "https://x.com/Athilio",
      "website": "https://athilio.com.br"
    }
  }
}
